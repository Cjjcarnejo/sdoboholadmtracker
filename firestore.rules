rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      // Bootstrapped Admin: cjjcarnejo@gmail.com
      return isSignedIn() && (
        request.auth.token.email == 'cjjcarnejo@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSchoolCoordinator(schoolId) {
      let userData = getUserData();
      return isSignedIn() && userData.role == 'School-Coordinator' && userData.schoolId == schoolId;
    }

    function isDistrictCoordinator(district) {
      let userData = getUserData();
      return isSignedIn() && userData.role == 'District-Coordinator' && userData.district == district;
    }

    // Pillar 2: Validation Blueprints
    function isValidStudent(data) {
      return data.lrn is string && data.lrn.size() == 12 && data.lrn.matches('^[0-9]+$') &&
             data.firstName is string && data.firstName.size() >= 1 && data.firstName.size() <= 100 &&
             data.lastName is string && data.lastName.size() >= 1 && data.lastName.size() <= 100 &&
             data.gradeLevel in ['Grade 7', 'Grade 8', 'Grade 9', 'Grade 10', 'Grade 11', 'Grade 12'] &&
             data.admType in ['Home Schooling', 'OHSP', 'Modular-Print', 'Modular-Digital', 'Radio-Based', 'TV-Based'] &&
             data.status in ['Active', 'Dropped', 'Transferred', 'Graduated'] &&
             isValidId(data.schoolId);
    }

    // 1. Schools
    match /schools/{schoolId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 2. Students
    match /students/{studentId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (
        isAdmin() ||
        resource.data.schoolId == getUserData().schoolId ||
        get(/databases/$(database)/documents/schools/$(resource.data.schoolId)).data.district == getUserData().district
      );

      allow create: if isSignedIn() && isValidStudent(incoming()) && (
        isAdmin() ||
        isSchoolCoordinator(incoming().schoolId)
      ) && exists(/databases/$(database)/documents/schools/$(incoming().schoolId));

      allow update: if (
        isSignedIn() && isValidStudent(incoming()) && (
          isAdmin() ||
          (isSchoolCoordinator(existing().schoolId) && incoming().schoolId == existing().schoolId)
        ) && (
          // Allow specific actions or fields
          incoming().diff(existing()).affectedKeys().hasOnly(['lrn', 'firstName', 'lastName', 'middleName', 'gradeLevel', 'section', 'admType', 'status', 'remarks', 'updatedAt'])
        )
      );

      allow delete: if isAdmin();
    }

    // 3. Users
    match /users/{userId} {
      allow read: if isUser(userId) || isAdmin();
      allow create: if isSignedIn() && isUser(userId) && 
                      incoming().role == 'School-Coordinator' && // Default role on self-signup? Or maybe admin only sets roles.
                      incoming().keys().hasAll(['uid', 'email', 'role']) &&
                      incoming().uid == request.auth.uid;
      
      allow update: if isAdmin() || (
        isUser(userId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['schoolId', 'district']) && // Users can't change their own role
        incoming().role == existing().role
      );
    }
    
    // 4. Admins
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console or specialized tool
    }
  }
}
