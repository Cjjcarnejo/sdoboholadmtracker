{
  "entities": {
    "Student": {
      "title": "ADM Student",
      "description": "Information about a student enrolled in Alternative Delivery Mode.",
      "type": "object",
      "properties": {
        "lrn": { "type": "string", "description": "Learner Reference Number" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "middleName": { "type": "string" },
        "gradeLevel": { "type": "string", "enum": ["Grade 7", "Grade 8", "Grade 9", "Grade 10", "Grade 11", "Grade 12"] },
        "section": { "type": "string" },
        "admType": { "type": "string", "enum": ["Home Schooling", "OHSP", "Modular-Print", "Modular-Digital", "Radio-Based", "TV-Based"] },
        "status": { "type": "string", "enum": ["Active", "Dropped", "Transferred", "Graduated"] },
        "schoolId": { "type": "string", "description": "ID of the school document" },
        "enrolledAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "remarks": { "type": "string" }
      },
      "required": ["lrn", "firstName", "lastName", "gradeLevel", "admType", "status", "schoolId"]
    },
    "School": {
      "title": "School",
      "description": "School details in SDO Bohol.",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "name": { "type": "string" },
        "district": { "type": "string" },
        "contactEmail": { "type": "string" }
      },
      "required": ["schoolId", "name", "district"]
    },
    "User": {
      "title": "Administrator User",
      "description": "User with access to manage student data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "School-Coordinator", "District-Coordinator"] },
        "schoolId": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/schools/{schoolId}": {
      "schema": "School",
      "description": "Collection of schools."
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Collection of ADM students."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User roles and permissions."
    }
  }
}
