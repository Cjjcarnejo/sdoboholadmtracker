rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isSystemAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() == 'cjjcarnejo@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidStudentRecord(data) {
      return data.keys().hasAll(['studentName', 'lastName', 'firstName', 'district', 'school', 'gender', 'grade', 'reasonForADM', 'academicStatus', 'assessment', 'duration', 'startDate', 'endDate', 'createdAt', 'createdBy'])
        && data.studentName is string && data.studentName.size() <= 200
        && data.lastName is string && data.lastName.size() <= 100
        && data.firstName is string && data.firstName.size() <= 100
        && data.district is string && data.district.size() <= 100
        && data.school is string && data.school.size() <= 200
        && data.gender in ['Male', 'Female']
        && data.grade in ['Kindergarten','Grade 1','Grade 2','Grade 3','Grade 4','Grade 5','Grade 6','Grade 7', 'Grade 8', 'Grade 9', 'Grade 10', 'Grade 11', 'Grade 12']
        && data.reasonForADM in ['Health Issues', 'Conflict Affected', 'Work Commitments', 'Children in Need of Care and Protection', 'Children in Conflict with the Law', 'Child Deprived with Liberty', 'Remote Areas', 'Others']
        && data.academicStatus in ['(90-100) Outstanding', '(85-89) Very Satisfactory', '(80-84) Satisfactory', '(75-79) Fairly Satisfactory', '(Below 75) Did not meet expectations']
        && data.assessment in ['Pending', 'Continue ADM', 'Back to Regular Class']
        && data.duration is string
        && data.startDate is string
        && data.endDate is string
        && data.createdAt is number
        && data.createdBy == request.auth.uid;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'fullName', 'email', 'district', 'role', 'createdAt'])
        && data.uid == request.auth.uid
        && data.fullName is string && data.fullName.size() <= 200
        && data.email == request.auth.token.email
        && data.district is string
        && data.role in ['admin', 'user']
        && data.createdAt is number;
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isSystemAdmin());
      allow list: if isSystemAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUserProfile(incoming());
      allow update: if isSignedIn() && (request.auth.uid == userId || isSystemAdmin())
                    && isValidUserProfile(incoming())
                    && (isSystemAdmin() || incoming().role == existing().role); // Users can't change their own role
      allow delete: if isSystemAdmin();
    }

    match /students/{studentId} {
      allow list: if isSignedIn() && (isSystemAdmin() || resource.data.createdBy == request.auth.uid);
      allow get: if isSignedIn() && isValidId(studentId) && (isSystemAdmin() || resource.data.createdBy == request.auth.uid);
      
      allow create: if isSignedIn() && isValidId(studentId) && isValidStudentRecord(incoming());
      
      allow update: if isSignedIn() && isValidId(studentId) 
                    && (isSystemAdmin() || (existing().createdBy == request.auth.uid && incoming().createdBy == existing().createdBy))
                    && isValidStudentRecord(incoming());
      
      allow delete: if isSignedIn() && isValidId(studentId) && (isSystemAdmin() || resource.data.createdBy == request.auth.uid);
    }
    
    match /test/connection {
      allow get: if true;
    }
  }
}
